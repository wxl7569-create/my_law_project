# ── Python 编译产物 ──
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
coverage.xml
htmlcov/

# ── 环境变量（含 API Key） ──
.env
.env.*
!.env.example

# ── 运行日志 ──
logfile/*.log
logfile/.__app.lock
*.log

# ── 数据库文件 ──
data/*.db
data/*.db-shm
data/*.db-wal
*.sqlite
*.sqlite3

# ── 运行时语音缓存 ──
data/voice_cache/
*.wav
*.mp3
*.m4a
*.webm

# ── Chroma 向量库（运行时重建） ──
chroma_law_civil/

# ── 本地模型文件（体积大，需用户自行下载） ──
models/

# ── IDE / 编辑器 ──
.vscode/
.idea/
*.swp
*.swo
*~

# ── OS 文件 ──
.DS_Store
Thumbs.db
desktop.ini

# ── 外部工具数据 ──
.workbuddy/

# ── 临时文件 ──
tmp/
temp/
*.tmp

.codex-project/